{% doc %}
  @prompt
    Related Products

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-related-products-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-related-products__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-related-products__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: {{ block.settings.title_margin }}px;
  }

  .ai-related-products__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0;
    font-weight: 600;
  }

  .ai-related-products__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-related-products__card-{{ ai_gen_id }} {
    background: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: 1px solid {{ block.settings.card_border_color }};
  }

  .ai-related-products__card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);
  }

  .ai-related-products__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    overflow: hidden;
  }

  .ai-related-products__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ai-related-products__card-{{ ai_gen_id }}:hover .ai-related-products__image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-related-products__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-related-products__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-related-products__badge-{{ ai_gen_id }} {
    position: absolute;
    top: 12px;
    left: 12px;
    background: {{ block.settings.sale_badge_color }};
    color: {{ block.settings.sale_badge_text_color }};
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
  }

  .ai-related-products__content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
  }

  .ai-related-products__vendor-{{ ai_gen_id }} {
    font-size: 12px;
    color: {{ block.settings.vendor_color }};
    margin-bottom: 4px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-related-products__title-link-{{ ai_gen_id }} {
    color: {{ block.settings.product_title_color }};
    text-decoration: none;
    display: block;
    margin-bottom: 8px;
  }

  .ai-related-products__product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_title_size }}px;
    font-weight: 500;
    margin: 0;
    line-height: 1.3;
  }

  .ai-related-products__price-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
  }

  .ai-related-products__price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    font-weight: 600;
    color: {{ block.settings.price_color }};
  }

  .ai-related-products__compare-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size | minus: 2 }}px;
    color: {{ block.settings.compare_price_color }};
    text-decoration: line-through;
  }

  .ai-related-products__button-{{ ai_gen_id }} {
    width: 100%;
    padding: 12px 16px;
    background: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: 1px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    display: inline-block;
    text-align: center;
  }

  .ai-related-products__button-{{ ai_gen_id }}:hover {
    background: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    transform: translateY(-1px);
  }

  .ai-related-products__empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #666;
  }

  .ai-related-products__empty-title-{{ ai_gen_id }} {
    font-size: 18px;
    margin-bottom: 8px;
    color: #333;
  }

  .ai-related-products__empty-text-{{ ai_gen_id }} {
    font-size: 14px;
    line-height: 1.5;
  }

  @media screen and (max-width: 990px) {
    .ai-related-products__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-related-products__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-related-products__container-{{ ai_gen_id }} {
      padding: 0 16px;
    }

    .ai-related-products__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<div class="ai-related-products-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-related-products__container-{{ ai_gen_id }}">
    {% if block.settings.title != blank %}
      <div class="ai-related-products__header-{{ ai_gen_id }}">
        <h2 class="ai-related-products__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      </div>
    {% endif %}

    {% liquid
      assign related_products = blank
      if block.settings.product_source == 'collection' and block.settings.collection != blank
        assign related_products = block.settings.collection.products
      elsif block.settings.product_source == 'manual' and block.settings.products != blank
        assign related_products = block.settings.products
      elsif block.settings.product_source == 'recommendations' and product
        assign related_products = product.related_products
      endif
    %}

    {% if related_products != blank and related_products.size > 0 %}
      <div class="ai-related-products__grid-{{ ai_gen_id }}">
        {% for related_product in related_products limit: block.settings.products_to_show %}
          <div class="ai-related-products__card-{{ ai_gen_id }}">
            <div class="ai-related-products__image-wrapper-{{ ai_gen_id }}">
              {% if related_product.featured_image %}
                <img
                  src="{{ related_product.featured_image | image_url: width: 400 }}"
                  alt="{{ related_product.featured_image.alt | escape }}"
                  class="ai-related-products__image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="400"
                  height="{{ 400 | divided_by: block.settings.image_aspect_ratio }}"
                >
              {% else %}
                <div class="ai-related-products__image-placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              {% endif %}

              {% if related_product.compare_at_price > related_product.price %}
                <div class="ai-related-products__badge-{{ ai_gen_id }}">
                  Sale
                </div>
              {% endif %}
            </div>

            <div class="ai-related-products__content-{{ ai_gen_id }}">
              {% if block.settings.show_vendor and related_product.vendor != blank %}
                <div class="ai-related-products__vendor-{{ ai_gen_id }}">
                  {{ related_product.vendor }}
                </div>
              {% endif %}

              <a href="{{ related_product.url }}" class="ai-related-products__title-link-{{ ai_gen_id }}">
                <h3 class="ai-related-products__product-title-{{ ai_gen_id }}">
                  {{ related_product.title }}
                </h3>
              </a>

              <div class="ai-related-products__price-wrapper-{{ ai_gen_id }}">
                <span class="ai-related-products__price-{{ ai_gen_id }}">
                  {{ related_product.price | money }}
                </span>
                {% if related_product.compare_at_price > related_product.price %}
                  <span class="ai-related-products__compare-price-{{ ai_gen_id }}">
                    {{ related_product.compare_at_price | money }}
                  </span>
                {% endif %}
              </div>

              {% if block.settings.show_add_to_cart %}<a href="{{ related_product.url }}" class="ai-related-products__button-{{ ai_gen_id }}">
                  {{ block.settings.button_text }}
                </a>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    {% else %}
      <div class="ai-related-products__empty-state-{{ ai_gen_id }}">
        <h3 class="ai-related-products__empty-title-{{ ai_gen_id }}">No related products found</h3>
        <p class="ai-related-products__empty-text-{{ ai_gen_id }}">
          {% if block.settings.product_source == 'collection' %}
            Select a collection to display related products.
          {% elsif block.settings.product_source == 'manual' %}
            Add products manually to display them here.
          {% else %}
            Related products will appear here when available.
          {% endif %}
        </p>
      </div>
    {% endif %}
  </div>
</div>

